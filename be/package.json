{
  "name": "@money-flow/be",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:kit": "drizzle-kit migrate --config drizzle.config.ts"
  },
  "dependencies": {
    "@fastify/multipart": "^9.3.0",
    "better-sqlite3": "^11.10.0",
    "csv-parse": "^5.6.0",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.2",
    "drizzle-kit": "^0.31.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
